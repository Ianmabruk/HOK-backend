DATABASE_URL=postgresql://user:password@localhost:5432/interior_db
JWT_SECRET_KEY=change-this-super-secret-key-in-production
FLASK_ENV=development

# Production backend setting: point this to your deployed frontend origin,
# for example:
# FRONTEND_URL=https://your-site.netlify.app
# This is the frontend website URL, not the GitHub repository URL.
FRONTEND_URL=http://localhost:5173

# Public URL used when the backend generates uploaded media links.
# In production this should be your live backend origin.
BACKEND_PUBLIC_URL=https://hok-backend-b5u6.onrender.com

# Optional durable media storage via Cloudinary.
# When these are set, product images and videos upload to Cloudinary instead of local disk.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
